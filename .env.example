# nSpeech Service Configuration

# Required: The TTS adapter backend to use
#   kokoro    - Ultra-fast CPU, 54 built-in voices, English only
#   cosyvoice - Multilingual (9 languages), zero-shot cloning, GPU required
#   chatterbox - Three models: Turbo (350M, paralinguistic), English (500M), Multilingual (500M)
NSPEECH_ENGINE=kokoro

# Required: Path to the directory storing reference audios and .pt voice caches
# Per-engine voice dirs: venv/<engine>/voices/
NSPEECH_VOICE_DIR=venv/kokoro/voices

# Required: Directory to store large TTS engine weights
# Per-engine model dirs are used automatically: venv/<engine>/models/
NSPEECH_MODEL_DIR=venv/kokoro/models

# ── Engine Examples ────────────────────────────────────────────
# CosyVoice:
# NSPEECH_ENGINE=cosyvoice
# NSPEECH_VOICE_DIR=venv/cosyvoice/voices
# NSPEECH_MODEL_DIR=venv/cosyvoice/models
#
# Chatterbox:
# NSPEECH_ENGINE=chatterbox
# NSPEECH_VOICE_DIR=venv/chatterbox/voices
# NSPEECH_MODEL_DIR=venv/chatterbox/models

# Server Bindings
NSPEECH_HOST=127.0.0.1
NSPEECH_PORT=2244

# Auth Token (Optional, leave blank for open access)
NSPEECH_API_KEY=

# Lifecycle
NSPEECH_PRELOAD_MODEL=false
NSPEECH_MODEL_IDLE_TIMEOUT_SEC=0
NSPEECH_LOG_LEVEL=INFO

# Transcoding
NSPEECH_TRANSCODE_SAMPLE_RATE=24000
NSPEECH_TRANSCODE_BITRATE=128k

# Logging
NSPEECH_LOG_DIR=logs
