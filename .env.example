# nSpeech Service Configuration

# Required: The TTS adapter backend to use (e.g., chatterbox, qwen3)
NSPEECH_ENGINE=kokoro

# Required: Path to the directory storing reference audios and .pt voice caches
# Per-engine voice dirs: venv/<engine>/voices/
NSPEECH_VOICE_DIR=venv/kokoro/voices

# Required: Directory to store large TTS engine weights
# Per-engine model dirs are used automatically: venv/<engine>/models/
NSPEECH_MODEL_DIR=venv/kokoro/models

# Server Bindings
NSPEECH_HOST=127.0.0.1
NSPEECH_PORT=8000

# Auth Token (Optional, leave blank for open access)
NSPEECH_API_KEY=

# Lifecycle
NSPEECH_PRELOAD_MODEL=false
NSPEECH_MODEL_IDLE_TIMEOUT_SEC=0
NSPEECH_LOG_LEVEL=INFO
